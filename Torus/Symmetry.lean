import Torus.Restriction
import GaussianField.Construction
import Nuclear.TensorProductFunctorAxioms

noncomputable section

namespace GaussianField

open NuclearTensorProduct SmoothMap_Circle

variable (L : ‚ĄĚ) [hL : Fact (0 < L)]

/-! ## Circle-level symmetry actions -/

/-- Reflection of a smooth periodic function: `(őėf)(x) = f(-x)`.

Continuity in Sobolev seminorms: `‚ÄĖ(őėf)^(k)‚ÄĖ_‚ąě ‚Č§ ‚ÄĖf^(k)‚ÄĖ_‚ąě`. -/
def circleReflection : SmoothMap_Circle L ‚ĄĚ ‚ÜíL[‚ĄĚ] SmoothMap_Circle L ‚ĄĚ where
  toLinearMap :=
    { toFun := fun f =>
        { toFun := fun x => f (-x)
          periodic' := fun x => by
            -- Goal: (fun x => f (-x)) (x + L) = (fun x => f (-x)) x
            -- i.e., f(-(x+L)) = f(-x)
            show f (-(x + L)) = f (-x)
            rw [show -(x + L) = -x - L from by ring]
            exact f.periodic'.neg (-x)
          smooth' := f.smooth'.comp contDiff_neg }
      map_add' := fun f g => by ext x; exact add_apply f g (-x)
      map_smul' := fun r f => by ext x; exact smul_apply r f (-x) }
  cont := by
    -- Continuity: reflection preserves all Sobolev sup norms
    -- The toLinearMap defined above
    set lm : SmoothMap_Circle L ‚ĄĚ ‚Üí‚āó[‚ĄĚ] SmoothMap_Circle L ‚ĄĚ :=
      { toFun := fun f =>
          { toFun := fun x => f (-x)
            periodic' := fun x => by
              show f (-(x + L)) = f (-x)
              rw [show -(x + L) = -x - L from by ring]
              exact f.periodic'.neg (-x)
            smooth' := f.smooth'.comp contDiff_neg }
        map_add' := fun f g => by ext x; exact add_apply f g (-x)
        map_smul' := fun r f => by ext x; exact smul_apply r f (-x) }
    change Continuous lm
    apply WithSeminorms.continuous_of_isBounded smoothCircle_withSeminorms smoothCircle_withSeminorms
    intro k
    refine ‚ü®{k}, ‚ü®‚ü®1, by norm_num‚ü©, fun f => ?_‚ü©‚ü©
    simp only [Seminorm.comp_apply, Finset.sup_singleton, Seminorm.smul_apply, NNReal.smul_def,
      NNReal.coe_mk, one_smul]
    -- Goal: sobolevSeminorm k (reflected f) ‚Č§ sobolevSeminorm k f
    exact sobolevSeminorm_affine_precomp_le (-1) 0 (by norm_num) k f _
      (fun x => by simp [lm, neg_mul])

/-- Translation of a smooth periodic function: `(T_v f)(x) = f(x - v)`. -/
def circleTranslation (v : ‚ĄĚ) :
    SmoothMap_Circle L ‚ĄĚ ‚ÜíL[‚ĄĚ] SmoothMap_Circle L ‚ĄĚ where
  toLinearMap :=
    { toFun := fun f =>
        { toFun := fun x => f (x - v)
          periodic' := fun x => by
            -- Goal after coercion: f(x + L - v) = f(x - v)
            change f (x + L - v) = f (x - v)
            rw [show x + L - v = (x - v) + L from by ring]
            exact f.periodic' (x - v)
          smooth' := f.smooth'.comp (contDiff_id.sub contDiff_const) }
      map_add' := fun f g => by ext x; exact add_apply f g (x - v)
      map_smul' := fun r f => by ext x; exact smul_apply r f (x - v) }
  cont := by
    -- Continuity: translation preserves all Sobolev sup norms
    set lm : SmoothMap_Circle L ‚ĄĚ ‚Üí‚āó[‚ĄĚ] SmoothMap_Circle L ‚ĄĚ :=
      { toFun := fun f =>
          { toFun := fun x => f (x - v)
            periodic' := fun x => by
              change f (x + L - v) = f (x - v)
              rw [show x + L - v = (x - v) + L from by ring]
              exact f.periodic' (x - v)
            smooth' := f.smooth'.comp (contDiff_id.sub contDiff_const) }
        map_add' := fun f g => by ext x; exact add_apply f g (x - v)
        map_smul' := fun r f => by ext x; exact smul_apply r f (x - v) }
    change Continuous lm
    apply WithSeminorms.continuous_of_isBounded smoothCircle_withSeminorms smoothCircle_withSeminorms
    intro k
    refine ‚ü®{k}, ‚ü®‚ü®1, by norm_num‚ü©, fun f => ?_‚ü©‚ü©
    simp only [Seminorm.comp_apply, Finset.sup_singleton, Seminorm.smul_apply, NNReal.smul_def,
      NNReal.coe_mk, one_smul]
    exact sobolevSeminorm_affine_precomp_le 1 (-v) (by norm_num) k f _
      (fun x => by show f (x - v) = f (1 * x + -v); ring_nf)

/-- Reflection is an involution: őė¬≤ = id. -/
theorem circleReflection_involution :
    (circleReflection L).comp (circleReflection L) =
    ContinuousLinearMap.id ‚ĄĚ _ := by
  ext f x
  simp [circleReflection, neg_neg]

/-- Translation by zero is the identity. -/
theorem circleTranslation_zero :
    circleTranslation L 0 = ContinuousLinearMap.id ‚ĄĚ _ := by
  ext f x
  simp [circleTranslation]

/-- Translation is additive: T_{u+v} = T_v ‚ąė T_u. -/
theorem circleTranslation_add (u v : ‚ĄĚ) :
    (circleTranslation L v).comp (circleTranslation L u) =
    circleTranslation L (u + v) := by
  ext f x
  simp [circleTranslation, sub_sub, add_comm u v]

/-! ## Torus-level symmetry actions -/

/-- Time reflection on the torus: `(őė ‚äó id)(f‚āĀ ‚äó f‚āā)(t,x) = f‚āĀ(-t) ‚äó f‚āā(x)`.

This is the Osterwalder-Schrader time reflection, acting on the first
(temporal) factor of `TorusTestFunction L = C‚ąě(S¬Ļ_L) ‚äóŐā C‚ąě(S¬Ļ_L)`. -/
def torusTimeReflection :
    TorusTestFunction L ‚ÜíL[‚ĄĚ] TorusTestFunction L :=
  nuclearTensorProduct_mapCLM
    (circleReflection L)
    (ContinuousLinearMap.id ‚ĄĚ (SmoothMap_Circle L ‚ĄĚ))

/-- Translation on the torus: `(T_{v‚āĀ} ‚äó T_{v‚āā})(f)(t,x) = f(t - v‚āĀ, x - v‚āā)`.

The full (‚ĄĚ/L‚Ą§)¬≤ translation group acts on `TorusTestFunction L`. -/
def torusTranslation (v : ‚ĄĚ √ó ‚ĄĚ) :
    TorusTestFunction L ‚ÜíL[‚ĄĚ] TorusTestFunction L :=
  nuclearTensorProduct_mapCLM
    (circleTranslation L v.1)
    (circleTranslation L v.2)

/-- Coordinate swap on the torus: `swap(f‚āĀ ‚äó f‚āā) = f‚āā ‚äó f‚āĀ`.

This generates the D4 point group together with reflections. For the
square torus T¬≤_L with equal periods, swapping (t,x) ‚Ü¶ (x,t) is a symmetry. -/
def torusSwap :
    TorusTestFunction L ‚ÜíL[‚ĄĚ] TorusTestFunction L :=
  nuclearTensorProduct_swapCLM

/-- Time reflection is an involution: őė¬≤ = id on the torus. -/
theorem torusTimeReflection_involution :
    (torusTimeReflection L).comp (torusTimeReflection L) =
    ContinuousLinearMap.id ‚ĄĚ _ := by
  -- őė = mapCLM(reflection, id), so őė¬≤ = mapCLM(reflection¬≤, id¬≤) = mapCLM(id, id) = id
  unfold torusTimeReflection
  rw [‚Üź nuclearTensorProduct_mapCLM_comp, circleReflection_involution,
      ContinuousLinearMap.id_comp]
  exact nuclearTensorProduct_mapCLM_id

/-! ## Configuration-level actions

Configuration = WeakDual ‚ĄĚ (TorusTestFunction L) = E ‚ÜíL[‚ĄĚ] ‚ĄĚ with weak-* topology.
Symmetry actions on test functions induce dual actions on configurations
by precomposition: `(T_* ŌČ)(f) = ŌČ(T f)`. -/

/-- Time reflection on configurations: `(őė_* ŌČ)(f) = ŌČ(őė f)`. -/
def torusConfigReflection :
    Configuration (TorusTestFunction L) ‚Üí Configuration (TorusTestFunction L) :=
  fun ŌČ => (ŌČ : TorusTestFunction L ‚ÜíL[‚ĄĚ] ‚ĄĚ).comp (torusTimeReflection L)

/-- Translation on configurations: `(T_{v,*} ŌČ)(f) = ŌČ(T_v f)`. -/
def torusConfigTranslation (v : ‚ĄĚ √ó ‚ĄĚ) :
    Configuration (TorusTestFunction L) ‚Üí Configuration (TorusTestFunction L) :=
  fun ŌČ => (ŌČ : TorusTestFunction L ‚ÜíL[‚ĄĚ] ‚ĄĚ).comp (torusTranslation L v)

/-- Time reflection on configurations is continuous.

For each test function f, the evaluation `ŌČ ‚Ü¶ (őė_* ŌČ)(f) = ŌČ(őėf)` is
a weak-* continuous functional (evaluation at the fixed element őėf).
Since the weak-* topology is initial for such evaluations, the map is
continuous. -/
theorem torusConfigReflection_continuous :
    Continuous (torusConfigReflection L) := by
  apply WeakDual.continuous_of_continuous_eval
  intro f
  -- (torusConfigReflection L ŌČ) f = ŌČ (torusTimeReflection L f)
  exact WeakDual.eval_continuous (torusTimeReflection L f)

/-- Translation on configurations is continuous. -/
theorem torusConfigTranslation_continuous (v : ‚ĄĚ √ó ‚ĄĚ) :
    Continuous (torusConfigTranslation L v) := by
  apply WeakDual.continuous_of_continuous_eval
  intro f
  exact WeakDual.eval_continuous (torusTranslation L v f)

/-- Time reflection on configurations is an involution. -/
theorem torusConfigReflection_involution (ŌČ : Configuration (TorusTestFunction L)) :
    torusConfigReflection L (torusConfigReflection L ŌČ) = ŌČ := by
  apply ContinuousLinearMap.ext
  intro f
  simp only [torusConfigReflection, ContinuousLinearMap.comp_apply]
  -- Goal: ŌČ (torusTimeReflection L (torusTimeReflection L f)) = ŌČ f
  congr 1
  exact ContinuousLinearMap.ext_iff.mp (torusTimeReflection_involution L) f

end GaussianField
