/-! ## Schwartz decay and integrability -/

/-- Schwartz functions on ‚ĄĚ satisfy the pointwise decay bound
`‚ÄĖf(t)‚ÄĖ ‚Č§ p_{k,0}(f) / (1 + ‚ÄĖt‚ÄĖ)^k`.

This is immediate from `SchwartzMap.norm_pow_mul_le_seminorm`. -/
private lemma schwartz_decay_bound (f : SchwartzMap ‚ĄĚ ‚ĄĚ) (k : ‚Ąē) (t : ‚ĄĚ) :
    (1 + ‚ÄĖt‚ÄĖ) ^ k * ‚ÄĖf.toFun t‚ÄĖ ‚Č§ SchwartzMap.seminorm ‚ĄĚ k 0 f := by
  sorry

/-- Schwartz functions are integrable on `[0, ‚ąě)` against `e^{-ŌČt}` for ŌČ > 0.

Proof: `|h(t) e^{-ŌČt}| ‚Č§ p_{2,0}(h) / (1+t)¬≤` and `(1+t)‚ĀĽ¬≤` is integrable
on `[0, ‚ąě)` since the integral equals 1. -/
private lemma schwartz_integrable_exp_neg (f : SchwartzMap ‚ĄĚ ‚ĄĚ) (ŌČ : ‚ĄĚ) (hŌČ : 0 < ŌČ) :
    IntegrableOn (fun t => f.toFun t * exp (-ŌČ * t)) (Ici 0) volume := by
  sorry

/-- The absolute value of the Laplace integral is bounded by `p_{2,0}(h)`.

Key computation:
  `|‚ąę‚āÄ^‚ąě h(t)e^{-ŌČt} dt| ‚Č§ ‚ąę‚āÄ^‚ąě |h(t)| dt ‚Č§ p_{2,0}(h) ¬∑ ‚ąę‚āÄ^‚ąě (1+t)‚ĀĽ¬≤ dt = p_{2,0}(h)`
-/
private lemma laplace_integral_bound (f : SchwartzMap ‚ĄĚ ‚ĄĚ) (ŌČ : ‚ĄĚ) (hŌČ : 0 < ŌČ) :
    ‚ÄĖ‚ąę t in Ici (0 : ‚ĄĚ), f.toFun t * exp (-ŌČ * t)‚ÄĖ ‚Č§
    SchwartzMap.seminorm ‚ĄĚ 2 0 f := by
  sorry

/-! ## Laplace evaluation CLM construction -/

/-- The Laplace evaluation as a linear map (before proving continuity). -/
private def laplaceEvalLinear (ŌČ : ‚ĄĚ) (hŌČ : 0 < ŌČ) : SchwartzMap ‚ĄĚ ‚ĄĚ ‚Üí‚āó[‚ĄĚ] ‚ĄĚ where
  toFun f := ‚ąę t in Ici (0 : ‚ĄĚ), f.toFun t * exp (-ŌČ * t)
  map_add' f g := by sorry
  map_smul' r f := by sorry

/-- **The Laplace evaluation CLM on Schwartz space.**

  `L_ŌČ(h) = ‚ąę‚āÄ^‚ąě h(t) e^{-ŌČt} dt`

Continuity follows from the bound `|L_ŌČ(h)| ‚Č§ p_{2,0}(h)`:
the Schwartz topology is generated by seminorms, and the composition
`|laplaceEvalLinear ŌČ| ‚Č§ p_{2,0}` shows continuity at 0. -/
def schwartzLaplaceEvalCLM (ŌČ : ‚ĄĚ) (hŌČ : 0 < ŌČ) : SchwartzMap ‚ĄĚ ‚ĄĚ ‚ÜíL[‚ĄĚ] ‚ĄĚ where
  toLinearMap := laplaceEvalLinear ŌČ hŌČ
  cont := by
    -- Continuity from the bound |L_ŌČ(h)| ‚Č§ p_{2,0}(h).
    -- p_{2,0} is a continuous seminorm, and the Laplace functional
    -- is bounded by it, hence continuous.
    sorry

/-- **Specification of the Laplace evaluation CLM.**

  `schwartzLaplaceEvalCLM ŌČ hŌČ h = ‚ąę t in Ici 0, h(t) ¬∑ e^{-ŌČt}` -/
theorem schwartzLaplaceEvalCLM_apply (ŌČ : ‚ĄĚ) (hŌČ : 0 < ŌČ) (h : SchwartzMap ‚ĄĚ ‚ĄĚ) :
    schwartzLaplaceEvalCLM ŌČ hŌČ h =
    ‚ąę t in Ici (0 : ‚ĄĚ), h.toFun t * exp (-ŌČ * t) := rfl

/-- **Uniform Schwartz seminorm bound for the Laplace evaluation.**

For `ŌČ ‚Č• mass > 0`, the bound `|L_ŌČ(h)| ‚Č§ C ¬∑ p(h)` holds with constants
independent of ŌČ. This is because `e^{-ŌČt} ‚Č§ 1` for `t ‚Č• 0, ŌČ > 0`, so
the integral `‚ąę‚āÄ^‚ąě |h(t)| e^{-ŌČt} dt ‚Č§ ‚ąę‚āÄ^‚ąě |h(t)| dt` is ŌČ-independent.

The Schwartz decay `|h(t)| ‚Č§ p_{2,0}(h) / (1+t)¬≤` then gives
`|L_ŌČ(h)| ‚Č§ p_{2,0}(h)` since `‚ąę‚āÄ^‚ąě (1+t)‚ĀĽ¬≤ dt = 1`. -/
theorem schwartzLaplace_uniformBound
    (mass : ‚ĄĚ) (hmass : 0 < mass) :
    ‚ąÉ (s : Finset (‚Ąē √ó ‚Ąē)) (C : ‚ĄĚ) (_ : 0 < C),
    ‚ąÄ (ŌČ : ‚ĄĚ) (hŌČ : mass ‚Č§ ŌČ) (h : SchwartzMap ‚ĄĚ ‚ĄĚ),
      |schwartzLaplaceEvalCLM ŌČ (lt_of_lt_of_le hmass hŌČ) h| ‚Č§
      C * (s.sup (fun m => SchwartzMap.seminorm (ūĚēú := ‚ĄĚ) (F := ‚ĄĚ) (E := ‚ĄĚ) m.1 m.2)) h := by
  refine ‚ü®{(2, 0)}, 1, one_pos, fun ŌČ hŌČ h => ?_‚ü©
  rw [schwartzLaplaceEvalCLM_apply]
  simp only [Finset.sup_singleton, one_mul]
  -- |x| = ‚ÄĖx‚ÄĖ for reals, so |‚ąę...| = ‚ÄĖ‚ąę...‚ÄĖ
  rw [show |‚ąę t in Ici (0 : ‚ĄĚ), h.toFun t * exp (-ŌČ * t)| =
    ‚ÄĖ‚ąę t in Ici (0 : ‚ĄĚ), h.toFun t * exp (-ŌČ * t)‚ÄĖ from (Real.norm_eq_abs _).symm]
  exact laplace_integral_bound h ŌČ (lt_of_lt_of_le hmass hŌČ)

end GaussianField
